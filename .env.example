# SMTP Configuration (e.g. Gmail, Mailgun, SendGrid, Brevo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Email sender display name & address
FROM_EMAIL="SafeReadAI Demo <demo@safereadai.dev>"

# Public base URL (no trailing slash)
BASE_URL=http://localhost:3000

# Server port
PORT=3000
